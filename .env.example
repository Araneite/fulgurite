# ── Répertoire des dépôts restic sur l'hôte ──────────────────────────────────
BACKUPS_PATH=/backups

# ── Base de données ───────────────────────────────────────────────────────────
# SQLite par défaut — aucune variable supplémentaire requise.
# Laisser DB_DRIVER=sqlite si vous n'utilisez pas --profile mysql/pgsql.
DB_DRIVER=sqlite

# ── SecretStore local chiffre ─────────────────────────────────────────────
# Cle maitre 32 octets en base64. Generez-la avec :
#   php bin/fulgurite-secret-key
# En production, preferez un Docker secret /run/secrets/fulgurite_secret_key
# ou un fichier /etc/fulgurite/secret.key lisible seulement par le service.
# FULGURITE_SECRET_KEY=

# ── MySQL (profil : mysql) ────────────────────────────────────────────────────
# Activer avec : docker compose --profile mysql up -d
# IMPORTANT : changer les mots de passe avant de déployer en production.
#
# DB_DRIVER=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=fulgurite
# DB_USER=fulgurite
# DB_PASS=un-mot-de-passe-fort
# MYSQL_ROOT_PASSWORD=un-autre-mot-de-passe-fort

# Secrets Fulgurite
# Production recommandee: broker local separe du process web.
# FULGURITE_SECRET_PROVIDER=agent
# FULGURITE_SECRET_AGENT_SOCKET=/run/fulgurite/secrets.sock
# FULGURITE_SECRET_AGENT_KEY=
# FULGURITE_WEB_USER=fulgurite-web
# FULGURITE_WEB_GROUP=fulgurite-web
# FULGURITE_PHP_FPM_SOCKET=/run/php/fulgurite-fpm.sock
#
# Fallback explicite seulement:
# FULGURITE_SECRET_PROVIDER=local
# FULGURITE_SECRET_KEY=

# ── PostgreSQL (profil : pgsql) ───────────────────────────────────────────────
# Activer avec : docker compose --profile pgsql up -d
# IMPORTANT : changer les mots de passe avant de déployer en production.
#
# DB_DRIVER=pgsql
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=fulgurite
# DB_USER=fulgurite
# DB_PASS=un-mot-de-passe-fort
