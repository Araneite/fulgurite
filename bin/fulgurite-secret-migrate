#!/usr/bin/env php
<?php

declare(strict_types=1);

define('FULGURITE_CLI', true);

require_once __DIR__ . '/../src/bootstrap.php';

$db = Database::getInstance();
$counts = ['repos' => 0, 'copy_jobs' => 0, 'hosts' => 0, 'skipped' => 0, 'errors' => 0];

function migrateLegacySecret(PDO $db, string $table, string $idColumn, string $fileColumn, string $refColumn, string $type, string $name, ?string $sourceColumn = null): int {
    $migrated = 0;
    $rows = $db->query("SELECT * FROM {$table} WHERE {$fileColumn} IS NOT NULL AND {$fileColumn} <> ''")->fetchAll();
    foreach ($rows as $row) {
        $id = (int) ($row[$idColumn] ?? 0);
        $file = (string) ($row[$fileColumn] ?? '');
        if ($id < 1 || $file === '' || !is_file($file)) {
            continue;
        }
        if (!empty($row[$refColumn]) && SecretStore::isSecretRef((string) $row[$refColumn]) && SecretStore::exists((string) $row[$refColumn])) {
            continue;
        }
        $value = trim((string) file_get_contents($file));
        if ($value === '') {
            continue;
        }
        $ref = SecretStore::writableRef($type, $id, $name);
        SecretStore::put($ref, $value, ['entity' => $table, 'id' => $id, 'legacy_file' => $file]);
        if ($sourceColumn !== null) {
            $db->prepare("UPDATE {$table} SET {$refColumn} = ?, {$sourceColumn} = ? WHERE {$idColumn} = ?")
                ->execute([$ref, SecretStore::providerNameForRef($ref), $id]);
        } else {
            $db->prepare("UPDATE {$table} SET {$refColumn} = ? WHERE {$idColumn} = ?")
                ->execute([$ref, $id]);
        }
        @unlink($file);
        $migrated++;
    }
    return $migrated;
}

try {
    $counts['repos'] = migrateLegacySecret($db, 'repos', 'id', 'password_file', 'password_ref', 'repo', 'password', 'password_source');
    $counts['copy_jobs'] = migrateLegacySecret($db, 'copy_jobs', 'id', 'dest_password_file', 'dest_password_ref', 'copy-job', 'dest-password', 'dest_password_source');
    $counts['hosts'] = migrateLegacySecret($db, 'hosts', 'id', 'sudo_password_file', 'sudo_password_ref', 'host', 'sudo');
} catch (Throwable $e) {
    $counts['errors']++;
    fwrite(STDERR, "Migration interrompue: " . $e->getMessage() . "\n");
}

echo json_encode($counts, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n";
exit($counts['errors'] > 0 ? 1 : 0);
