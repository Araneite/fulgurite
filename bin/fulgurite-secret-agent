#!/usr/bin/env php
<?php

declare(strict_types=1);

define('FULGURITE_CLI', true);

require_once __DIR__ . '/../config/config.php';
require_once __DIR__ . '/../src/Profiler.php';
require_once __DIR__ . '/../src/Database.php';
require_once __DIR__ . '/../src/InfisicalClient.php';
require_once __DIR__ . '/../src/SecretRedaction.php';
require_once __DIR__ . '/../src/SecretStore.php';

$bind = SecretStore::env('FULGURITE_SECRET_AGENT_BIND', '');
$socketPath = SecretStore::env('FULGURITE_SECRET_AGENT_SOCKET', '/run/fulgurite/secrets.sock');
if ($bind === '') {
    $bind = str_starts_with($socketPath, 'unix://') ? $socketPath : ('unix://' . $socketPath);
}
$auditPath = SecretStore::env('FULGURITE_SECRET_AGENT_AUDIT', SecretStore::env('FULGURITE_SECRET_AGENT_AUDIT_LOG', '/var/lib/fulgurite-secrets/audit.log'));
$nodeId = trim(SecretStore::env('FULGURITE_SECRET_AGENT_NODE_ID', gethostname() ?: 'secret-broker'));
$nodeLabel = trim(SecretStore::env('FULGURITE_SECRET_AGENT_NODE_LABEL', $nodeId));
$clusterName = trim(SecretStore::env('FULGURITE_SECRET_AGENT_CLUSTER_NAME', 'fulgurite-secret-broker'));
$publicEndpoint = trim(SecretStore::env('FULGURITE_SECRET_AGENT_PUBLIC_ENDPOINT', $bind));
$peerEndpoints = HaBrokerSecretProvider::parseEndpoints(SecretStore::env('FULGURITE_SECRET_AGENT_CLUSTER_PEERS', ''));
$provider = LocalEncryptedSecretProvider::forAgent();
$agentDb = (static function () use ($provider): PDO {
    $reflection = new ReflectionClass($provider);
    $property = $reflection->getProperty('db');
    $property->setAccessible(true);
    return $property->getValue($provider);
})();

function agentRespond($conn, array $payload): void {
    fwrite($conn, json_encode($payload, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n");
}

function agentValidateRef(string $ref): void {
    if (preg_match('#^secret://agent/[a-z0-9_-]+/[1-9][0-9]*/[a-z0-9_-]+$#', $ref) !== 1) {
        throw new InvalidArgumentException('Reference de secret invalide.');
    }
}

function agentValidatePurpose(string $purpose): string {
    $purpose = strtolower(trim($purpose));
    $allowed = ['runtime', 'backup', 'copy', 'restore', 'sudo', 'migration', 'setup', 'health', 'audit'];
    if (!in_array($purpose, $allowed, true)) {
        throw new InvalidArgumentException('Purpose invalide.');
    }
    return $purpose;
}

function agentNowExpression(PDO $db): string {
    return match ((string) $db->getAttribute(PDO::ATTR_DRIVER_NAME)) {
        'mysql', 'pgsql' => 'NOW()',
        default => "datetime('now')",
    };
}

function agentAudit(PDO $db, string $auditPath, string $nodeId, string $nodeLabel, string $clusterName, string $action, string $ref, string $purpose, bool $ok, array $details = []): void {
    try {
        $db->prepare("
            INSERT INTO app_secret_audit (node_id, node_label, cluster_name, action, secret_ref, purpose, ok, details_json, ts)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, " . agentNowExpression($db) . ")
        ")->execute([
            $nodeId,
            $nodeLabel,
            $clusterName,
            $action,
            $ref !== '' ? $ref : null,
            $purpose,
            $ok ? 1 : 0,
            json_encode(SecretRedaction::redactValue($details), JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) ?: '{}',
        ]);
    } catch (Throwable $e) {
    }

    $dir = dirname($auditPath);
    if (!is_dir($dir)) {
        @mkdir($dir, 0700, true);
    }
    $line = json_encode([
        'ts' => gmdate('c'),
        'node_id' => $nodeId,
        'node_label' => $nodeLabel,
        'cluster_name' => $clusterName,
        'action' => $action,
        'secret_ref' => $ref,
        'purpose' => $purpose,
        'ok' => $ok,
        'details' => SecretRedaction::redactValue($details),
    ], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n";
    @file_put_contents($auditPath, $line, FILE_APPEND | LOCK_EX);
}

function agentReadAuditTail(PDO $db, string $auditPath, int $limit): array {
    $limit = max(1, min(500, $limit));
    try {
        $stmt = $db->prepare("
            SELECT ts, node_id, node_label, cluster_name, action, secret_ref, purpose, ok, details_json
            FROM app_secret_audit
            ORDER BY ts DESC, id DESC
            LIMIT ?
        ");
        $stmt->bindValue(1, $limit, PDO::PARAM_INT);
        $stmt->execute();
        $rows = $stmt->fetchAll();
        if (is_array($rows) && !empty($rows)) {
            return array_reverse(array_map(static function (array $row): array {
                return [
                    'ts' => (string) ($row['ts'] ?? ''),
                    'node_id' => (string) ($row['node_id'] ?? ''),
                    'node_label' => (string) ($row['node_label'] ?? ''),
                    'cluster_name' => (string) ($row['cluster_name'] ?? ''),
                    'action' => (string) ($row['action'] ?? ''),
                    'secret_ref' => (string) ($row['secret_ref'] ?? ''),
                    'purpose' => (string) ($row['purpose'] ?? ''),
                    'ok' => !empty($row['ok']),
                    'details' => is_array(json_decode((string) ($row['details_json'] ?? '{}'), true)) ? json_decode((string) ($row['details_json'] ?? '{}'), true) : [],
                ];
            }, $rows));
        }
    } catch (Throwable $e) {
    }

    if (!is_file($auditPath) || !is_readable($auditPath)) {
        return [];
    }
    $lines = file($auditPath, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    if (!is_array($lines)) {
        return [];
    }
    $tail = array_slice($lines, -$limit);
    $logs = [];
    foreach ($tail as $line) {
        $row = json_decode((string) $line, true);
        if (!is_array($row)) {
            continue;
        }
        $logs[] = [
            'ts' => (string) ($row['ts'] ?? ''),
            'node_id' => (string) ($row['node_id'] ?? ''),
            'node_label' => (string) ($row['node_label'] ?? ''),
            'cluster_name' => (string) ($row['cluster_name'] ?? ''),
            'action' => (string) ($row['action'] ?? ''),
            'secret_ref' => (string) ($row['secret_ref'] ?? ''),
            'purpose' => (string) ($row['purpose'] ?? ''),
            'ok' => !empty($row['ok']),
            'details' => is_array($row['details'] ?? null) ? $row['details'] : [],
        ];
    }
    return $logs;
}

function agentRequestPeerHealth(array $peer, float $timeoutSeconds): array {
    $address = $peer['uri'];
    $errno = 0;
    $errstr = '';
    $stream = @stream_socket_client($address, $errno, $errstr, $timeoutSeconds, STREAM_CLIENT_CONNECT);
    if (!is_resource($stream)) {
        throw new RuntimeException('Peer indisponible: ' . $errstr);
    }
    stream_set_timeout($stream, (int) max(1, ceil($timeoutSeconds)));
    fwrite($stream, "{\"action\":\"health\",\"purpose\":\"health\"}\n");
    $line = fgets($stream);
    fclose($stream);
    if (!is_string($line) || trim($line) === '') {
        throw new RuntimeException('Reponse vide du peer.');
    }
    $response = json_decode($line, true);
    if (!is_array($response) || empty($response['ok'])) {
        throw new RuntimeException((string) ($response['error'] ?? 'Erreur peer.'));
    }
    return $response;
}

function agentClusterHealth(array $self, array $peerEndpoints, float $timeoutSeconds): array {
    $nodes = [[
        'endpoint' => (string) ($self['bind'] ?? ''),
        'public_endpoint' => (string) ($self['endpoint'] ?? ''),
        'node_id' => (string) ($self['node_id'] ?? ''),
        'node_label' => (string) ($self['node_label'] ?? ''),
        'cluster_name' => (string) ($self['cluster_name'] ?? ''),
        'backend' => (string) ($self['backend'] ?? ''),
        'ok' => true,
    ]];

    foreach ($peerEndpoints as $peer) {
        try {
            $response = agentRequestPeerHealth($peer, $timeoutSeconds);
            $nodes[] = [
                'endpoint' => $peer['uri'],
                'public_endpoint' => (string) ($response['endpoint'] ?? $peer['uri']),
                'node_id' => (string) ($response['node_id'] ?? ''),
                'node_label' => (string) ($response['node_label'] ?? ''),
                'cluster_name' => (string) ($response['cluster_name'] ?? ''),
                'backend' => (string) ($response['backend'] ?? ''),
                'ok' => true,
            ];
        } catch (Throwable $e) {
            $nodes[] = [
                'endpoint' => $peer['uri'],
                'public_endpoint' => $peer['uri'],
                'node_id' => '',
                'node_label' => '',
                'cluster_name' => (string) ($self['cluster_name'] ?? ''),
                'backend' => '',
                'ok' => false,
                'error' => SecretRedaction::safeThrowableMessage($e),
            ];
        }
    }

    $healthy = count(array_filter($nodes, static fn(array $node): bool => !empty($node['ok'])));
    return [
        'ok' => $healthy > 0,
        'cluster_name' => (string) ($self['cluster_name'] ?? ''),
        'selected_endpoint' => (string) ($self['endpoint'] ?? ''),
        'healthy' => $healthy,
        'total' => count($nodes),
        'degraded' => $healthy > 0 && $healthy < count($nodes),
        'nodes' => $nodes,
    ];
}

if (str_starts_with($bind, 'unix://')) {
    $unixPath = substr($bind, 7);
    if ($unixPath !== '' && is_file($unixPath)) {
        @unlink($unixPath);
    }
    if ($unixPath !== '' && !is_dir(dirname($unixPath))) {
        mkdir(dirname($unixPath), 0770, true);
    }
} elseif (preg_match('#^tcp://([^:]+):(\d+)$#', $bind, $matches) === 1) {
    // host and port already validated by regex
} else {
    fwrite(STDERR, "FULGURITE_SECRET_AGENT_BIND invalide: {$bind}\n");
    exit(1);
}

$server = @stream_socket_server($bind, $errno, $errstr);
if (!is_resource($server)) {
    fwrite(STDERR, "Impossible d'ouvrir le broker secrets: {$errstr}\n");
    exit(1);
}
if (str_starts_with($bind, 'unix://')) {
    @chmod(substr($bind, 7), 0660);
}

fwrite(STDERR, "fulgurite-secret-agent listening on {$bind}\n");

while ($conn = @stream_socket_accept($server, -1)) {
    $line = fgets($conn);
    $ok = false;
    $action = '';
    $ref = '';
    $purpose = 'runtime';
    try {
        $request = json_decode((string) $line, true);
        if (!is_array($request)) {
            throw new InvalidArgumentException('JSON invalide.');
        }
        $action = strtolower(trim((string) ($request['action'] ?? '')));
        $ref = (string) ($request['secret_ref'] ?? '');
        $purpose = agentValidatePurpose((string) ($request['purpose'] ?? 'runtime'));

        $healthPayload = [
            'ok' => true,
            'provider' => 'agent',
            'node_id' => $nodeId,
            'node_label' => $nodeLabel,
            'cluster_name' => $clusterName,
            'endpoint' => $publicEndpoint,
            'bind' => $bind,
            'backend' => $agentDb->getAttribute(PDO::ATTR_DRIVER_NAME),
            'status' => 'ready',
        ];

        if ($action === 'health') {
            $ok = true;
            agentRespond($conn, $healthPayload);
            fclose($conn);
            continue;
        }

        if ($action === 'cluster_health') {
            $cluster = agentClusterHealth([
                'node_id' => $nodeId,
                'node_label' => $nodeLabel,
                'cluster_name' => $clusterName,
                'endpoint' => $publicEndpoint,
                'bind' => $bind,
                'backend' => $agentDb->getAttribute(PDO::ATTR_DRIVER_NAME),
            ], $peerEndpoints, (float) SecretStore::env('FULGURITE_SECRET_AGENT_TIMEOUT', '2.0'));
            $ok = true;
            agentRespond($conn, ['ok' => true, 'provider' => 'agent', 'cluster' => $cluster]);
            fclose($conn);
            continue;
        }

        if ($action === 'audit_tail') {
            $limit = (int) ($request['limit'] ?? 200);
            $logs = agentReadAuditTail($agentDb, $auditPath, $limit);
            $ok = true;
            agentRespond($conn, [
                'ok' => true,
                'audit_path' => $auditPath,
                'cluster_name' => $clusterName,
                'node_id' => $nodeId,
                'logs' => $logs,
            ]);
            fclose($conn);
            continue;
        }

        agentValidateRef($ref);

        if ($action === 'put') {
            $value = (string) ($request['value'] ?? '');
            $metadata = is_array($request['metadata'] ?? null) ? $request['metadata'] : [];
            $provider->put($ref, $value, $metadata);
            $ok = true;
            agentRespond($conn, ['ok' => true]);
        } elseif ($action === 'get') {
            $value = $provider->get($ref, $purpose, is_array($request['context'] ?? null) ? $request['context'] : []);
            $ok = $value !== null;
            agentRespond($conn, $value === null ? ['ok' => false, 'error' => 'Secret introuvable.'] : ['ok' => true, 'value' => $value]);
        } elseif ($action === 'delete') {
            $provider->delete($ref);
            $ok = true;
            agentRespond($conn, ['ok' => true]);
        } elseif ($action === 'exists') {
            $exists = $provider->exists($ref);
            $ok = true;
            agentRespond($conn, ['ok' => true, 'exists' => $exists]);
        } else {
            throw new InvalidArgumentException('Action non supportee.');
        }
    } catch (Throwable $e) {
        agentRespond($conn, ['ok' => false, 'error' => SecretRedaction::safeThrowableMessage($e)]);
    } finally {
        if (!in_array($action, ['health', 'cluster_health'], true)) {
            agentAudit($agentDb, $auditPath, $nodeId, $nodeLabel, $clusterName, $action, $ref, $purpose, $ok);
        }
        fclose($conn);
    }
}
