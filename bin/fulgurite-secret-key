#!/usr/bin/env php
<?php

define('FULGURITE_CLI', true);

if (PHP_SAPI !== 'cli') {
    fwrite(STDERR, "Cette commande doit etre lancee localement en CLI.\n");
    exit(64);
}

require_once __DIR__ . '/../config/config.php';
require_once __DIR__ . '/../src/SecretStore.php';

if (in_array('--help', $argv, true) || in_array('-h', $argv, true)) {
    fwrite(STDERR, "Usage: php bin/fulgurite-secret-key\n");
    fwrite(STDERR, "Affiche une cle FULGURITE_SECRET_KEY base64 de 32 octets.\n");
    exit(0);
}

echo SecretStore::generateKey() . PHP_EOL;

